{
  "Cmake new project": {
    "prefix": ["new_project"],
    "body": [
    "cmake_minimum_required(VERSION ${1:4.0})",
    "project(",
    " \"${2}\"",
    " VERSION 1.0",
    " DESCRIPTION \"${3:}\"",
    " LANGUAGES ${4:CXX}",
    ")",
    "",
    "set(CXX_STANDARD_REQUIRED true)",
    "",
    "add_executable(${5})",
    "set_property(TARGET ${5} PROPERTY CXX_STANDARD ${6})",
    "target_sources(${5}",
    " PRIVATE",
    " src/${7:main}.cpp",
    ")"
    ],
    "description": "Create new C++ project",
    "scope": "cmake",
    "include": "CMakeLists.txt"
  }
}


