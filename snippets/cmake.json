{
  "Cmake new project": {
    "prefix": ["new_project"],
    "body": [
    "cmake_minimum_required(VERSION ${1:4.0})",
    "project(\"$2\"",
    " VERSION ${3:1.0}",
    " DESCRIPTION \"$4\"",
    " LANGUAGES ${5:|CXX,C|}",
    ")",
    "",
    "set(CXX_STANDARD_REQUIRED true)",
    "set(CMAKE_CXX_STANDARD $6)",
    "",
    "add_executable($7)",
    "target_sources($7",
    " PRIVATE",
    " src/$8.cpp",
    ")"
    ],
    "description": "Create new C++ project",
    "scope": "cmake",
    "include": "CMakeLists.txt"
  }
}
