{
  "Cmake new project": {
    "prefix": ["new_project"],
    "body": [
    "cmake_minimum_required(VERSION ${1:4.0})",
    "project(\"$2\"",
    " VERSION ${3:1.0}",
    " DESCRIPTION \"$4\"",
    " LANGUAGES ${5|CXX,C|}",
    ")",
    "",
    "set(CMAKE_${5}_STANDARD ${6:23})",
    "set(CMAKE_${5}_STANDARD_REQUIRED ${7|ON,OFF|})",
    "set(CMAKE_BUILD_TYPE ${8|Debug,Release,RelWithDebInfo,MinSizeRel|})",
    "",
    "file(GLOB_RECURSE SRC_FILES",
    " CONFIGURE_DEPENDS",
    " \"\\${CMAKE_CURRENT_SOURCE_DIR}/src/*.${9|cpp,c|}\"",
    ")",
    "",
    "add_executable(\"$2\" \\${SRC_FILES})",
    "",
    "message(STATUS \"\")",
    "message(STATUS \"_*_ Build Info _*_\")",
    "message(STATUS \"Configuring project: \\${PROJECT_NAME}\")",
    "if(NOT \"\\${PROJECT_DESCRIPTION}\" STREQUAL \"\")",
    "  message(STATUS \"Project Description: \\${PROJECT_DESCRIPTION}\")",
    "endif()",
    "message(STATUS \"Build Type: \\${CMAKE_BUILD_TYPE}\")",
    "if (\\${CMAKE_${5}_STANDARD_REQUIRED})",
    "  message(STATUS \"${5/(CXX|C)/(?1:C++:C)/} Standard: \\${CMAKE_${5}_STANDARD}\")",
    "endif()"
    ],
    "description": "Create new C++ project",
    "scope": "cmake",
    "include": "CMakeLists.txt"
  },
  "Cmake link libraries": {
    "prefix": ["link_libraries"],
    "body": [
      "target_link_libraries(${1:TARGET} \"${2:LIB}\")"
    ],
    "description": "Link target with a library",
    "scope": "cmake",
    "include": "CMakeLists.txt"
  }
}
