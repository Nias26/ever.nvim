{
  "Clangd config": {
    "prefix": ["set_cpp_standard"],
    "body": [
      "If:",
      " PathMatch: .*\\.cpp",
      "",
      "CompileFlags:",
      " Add: [--std=c++${1:23}]",
      "",
      "---"
    ],
    "description": "Set C++ standard for clangd",
    "scope": "yaml",
    "include": ".clangd"
  }
}
